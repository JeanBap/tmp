<?xml version="1.0" encoding="utf-8"?>
<!--
    Disabilita esplicitamente l'auto-backup di Android e il device-to-device
    transfer per i dati dell'app. Un vault KeePass deve essere esportato
    manualmente dall'utente, non finire automaticamente nel cloud di Google.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
